# OpenAI-compatible 模型配置。API Key 留空时自动进入 mock 模式。
# API Key 只能由后端读取；不要改成 VITE_* 变量，也不要把真实值提交到 Git。
OPENAI_API_KEY=

# 基础地址不要包含 /chat/completions。
# OpenAI: https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com
# 通义千问兼容模式请填写其 OpenAI-compatible 基础地址。
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.4
OPENAI_TIMEOUT_MS=30000

# 兼容旧配置：LLM_API_KEY、LLM_BASE_URL、LLM_MODEL、
# LLM_TEMPERATURE、LLM_TIMEOUT_MS 仍可使用，但新变量优先。

# 后端端口。Vite 开发代理默认对应 3001。
PORT=3001

# 仅输出不含对话正文和身份信息的结构化日志。未配置时默认关闭。
ENABLE_SAFE_LOG=true

# 公开试用时建议开启。未配置或设为 false 时关闭限流。
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# Optional knowledge context diagnostics. Defaults are false.
KNOWLEDGE_CONTEXT_ENABLED=false
KNOWLEDGE_CONTEXT_DEBUG=false
KNOWLEDGE_CONTEXT_PROMPT_ENABLED=false
