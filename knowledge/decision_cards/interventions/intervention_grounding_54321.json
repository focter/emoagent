  "steps": [
    "说出 5 个看到的事物",
    "感受 4 个能触碰到的事物",
    "注意 3 个听到的声音",
    "辨认 2 种气味",
    "注意 1 种味道或口腔感受"
  ],
  "max_duration_minutes": 5,
